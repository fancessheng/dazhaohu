/* app.wxss - 全局样式 */

/* 颜色变量 - Tiffany 蓝主色调 */
page {
  --color-primary: #0ABFBC;
  --color-primary-light: #4DD9D6;
  --color-primary-dark: #089E9B;
  --color-primary-bg: #E6F9F8;
  --color-success: #10B981;
  --color-warning: #F59E0B;
  --color-danger: #EF4444;
  --color-text-primary: #1A1A2E;
  --color-text-secondary: #5C6370;
  --color-text-muted: #9CA3AF;
  --color-border: #E8ECEF;
  --color-bg: #F4F7F8;
  --color-white: #FFFFFF;

  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', 'PingFang SC', 'Hiragino Sans GB', 'Microsoft YaHei', sans-serif;
  font-size: 28rpx;
  color: var(--color-text-primary);
  background-color: var(--color-bg);
  box-sizing: border-box;
}

/* 通用容器 */
.container {
  padding: 32rpx;
  min-height: 100vh;
  box-sizing: border-box;
}

/* 卡片样式 */
.card {
  background: var(--color-white);
  border-radius: 16rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
}

.card-title {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--color-text-primary);
  margin-bottom: 16rpx;
}

.card-desc {
  font-size: 26rpx;
  color: var(--color-text-secondary);
  line-height: 1.6;
}

/* 按钮样式 */
.btn-primary {
  background: var(--color-primary);
  color: #FFFFFF;
  border: none;
  border-radius: 12rpx;
  padding: 24rpx 48rpx;
  font-size: 30rpx;
  font-weight: 500;
  text-align: center;
  width: 100%;
}

.btn-primary:active {
  background: var(--color-primary-dark);
}

.btn-primary[disabled] {
  background: #B2E8E7;
  color: #FFFFFF;
}

.btn-outline {
  background: transparent;
  color: var(--color-primary);
  border: 2rpx solid var(--color-primary);
  border-radius: 12rpx;
  padding: 24rpx 48rpx;
  font-size: 30rpx;
  font-weight: 500;
  text-align: center;
  width: 100%;
}

/* 文本域 */
.textarea-wrapper {
  border: 2rpx solid var(--color-border);
  border-radius: 12rpx;
  padding: 24rpx;
  background: var(--color-white);
}

.textarea-wrapper textarea {
  width: 100%;
  min-height: 200rpx;
  font-size: 28rpx;
  line-height: 1.6;
}

/* 上传区域 */
.upload-area {
  border: 2rpx dashed var(--color-border);
  border-radius: 16rpx;
  padding: 48rpx 32rpx;
  text-align: center;
  background: var(--color-bg);
  transition: all 0.3s;
}

.upload-area:active {
  border-color: var(--color-primary-light);
  background: var(--color-primary-bg);
}

.upload-icon {
  font-size: 64rpx;
  margin-bottom: 16rpx;
}

.upload-text {
  font-size: 28rpx;
  color: var(--color-text-secondary);
}

.upload-hint {
  font-size: 24rpx;
  color: var(--color-text-muted);
  margin-top: 8rpx;
}

/* 标签 */
.tag {
  display: inline-block;
  padding: 6rpx 16rpx;
  border-radius: 8rpx;
  font-size: 22rpx;
  font-weight: 500;
}

.tag-primary {
  background: var(--color-primary-bg);
  color: var(--color-primary);
}

.tag-success {
  background: #D1FAE5;
  color: #059669;
}

.tag-warning {
  background: #FEF3C7;
  color: #D97706;
}

/* 分割线 */
.divider {
  height: 1rpx;
  background: var(--color-border);
  margin: 24rpx 0;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 80rpx 0;
  color: var(--color-text-muted);
}

.empty-icon {
  font-size: 96rpx;
  margin-bottom: 24rpx;
}

.empty-text {
  font-size: 28rpx;
}

/* 加载动画 */
.loading-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  z-index: 999;
}

.loading-spinner {
  width: 64rpx;
  height: 64rpx;
  border: 4rpx solid rgba(255, 255, 255, 0.3);
  border-top-color: #FFFFFF;
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
}

.loading-text {
  color: #FFFFFF;
  font-size: 28rpx;
  margin-top: 24rpx;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

/* Toast */
.toast {
  position: fixed;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  background: rgba(0, 0, 0, 0.75);
  color: #FFFFFF;
  padding: 20rpx 40rpx;
  border-radius: 12rpx;
  font-size: 28rpx;
  z-index: 1000;
}
