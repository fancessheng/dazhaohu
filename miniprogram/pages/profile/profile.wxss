/* 个人中心样式 */

/* 用户头部 */
.user-header {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 48rpx 0 32rpx;
}

.avatar {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  background: var(--color-primary-bg);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 16rpx;
  overflow: hidden;
}

.avatar-img {
  width: 100%;
  height: 100%;
  border-radius: 50%;
}

.avatar-placeholder {
  font-size: 56rpx;
}

.user-name {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--color-text-primary);
  margin-bottom: 8rpx;
}

.user-id {
  font-size: 24rpx;
  color: var(--color-text-muted);
}

/* 会员状态 */
.membership-card {
  background: linear-gradient(135deg, #4F46E5 0%, #7C3AED 100%);
  color: #FFFFFF;
}

.membership-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
}

.membership-title {
  font-size: 30rpx;
  font-weight: 600;
}

.membership-card .tag {
  background: rgba(255, 255, 255, 0.2);
  color: #FFFFFF;
  border: 1rpx solid rgba(255, 255, 255, 0.3);
}

.quota-display {
  display: flex;
  align-items: center;
  padding: 24rpx 0;
  margin-bottom: 24rpx;
  border-top: 1rpx solid rgba(255, 255, 255, 0.2);
  border-bottom: 1rpx solid rgba(255, 255, 255, 0.2);
}

.quota-item {
  flex: 1;
  text-align: center;
}

.quota-value {
  display: block;
  font-size: 48rpx;
  font-weight: 700;
  line-height: 1;
  margin-bottom: 8rpx;
}

.quota-divider {
  width: 1rpx;
  height: 60rpx;
  background: rgba(255, 255, 255, 0.3);
}

.quota-item .quota-label {
  color: rgba(255, 255, 255, 0.7);
  font-size: 22rpx;
}

.upgrade-section {
  text-align: center;
}

.upgrade-desc {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.7);
  margin-bottom: 16rpx;
  display: block;
}

.upgrade-btn {
  background: rgba(255, 255, 255, 0.2) !important;
  color: #FFFFFF !important;
  border: 2rpx solid rgba(255, 255, 255, 0.4) !important;
}

.premium-info {
  text-align: center;
}

.premium-desc {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.9);
}

/* 简历预览 */
.resume-preview {
  background: var(--color-bg);
  border-radius: 10rpx;
  padding: 24rpx;
  max-height: 300rpx;
  overflow: hidden;
  position: relative;
}

.resume-text {
  font-size: 26rpx;
  color: var(--color-text-secondary);
  line-height: 1.6;
  display: -webkit-box;
  -webkit-line-clamp: 6;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.resume-actions {
  display: flex;
  justify-content: flex-end;
  gap: 32rpx;
  margin-top: 16rpx;
}

.action-link {
  font-size: 26rpx;
  color: var(--color-primary);
}

.action-link.danger {
  color: var(--color-danger);
}

/* 使用说明 */
.guide-list {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.guide-item {
  display: flex;
  gap: 20rpx;
}

.guide-num {
  width: 44rpx;
  height: 44rpx;
  background: var(--color-primary-bg);
  color: var(--color-primary);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  font-weight: 600;
  flex-shrink: 0;
}

.guide-content {
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}

.guide-title {
  font-size: 28rpx;
  font-weight: 500;
  color: var(--color-text-primary);
}

.guide-desc {
  font-size: 24rpx;
  color: var(--color-text-muted);
  line-height: 1.5;
}

/* 底部 */
.footer {
  text-align: center;
  padding: 48rpx 0;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.footer-text {
  font-size: 22rpx;
  color: var(--color-text-muted);
}
