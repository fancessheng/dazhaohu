/* 结果页样式 */

.success-header {
  text-align: center;
  padding: 40rpx 0 32rpx;
}

.success-icon {
  font-size: 96rpx;
  margin-bottom: 16rpx;
}

.success-title {
  font-size: 36rpx;
  font-weight: 700;
  color: var(--color-text-primary);
  margin-bottom: 8rpx;
}

.success-subtitle {
  font-size: 28rpx;
  color: var(--color-primary);
  margin-bottom: 12rpx;
}

.success-tips {
  display: inline-block;
  padding: 8rpx 24rpx;
  background: #FEF3C7;
  color: #D97706;
  border-radius: 20rpx;
  font-size: 24rpx;
}

/* 话术卡片 */
.script-card {
  position: relative;
}

.card-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
  padding-bottom: 20rpx;
  border-bottom: 1rpx solid var(--color-border);
}

.copy-btn {
  padding: 8rpx 20rpx;
  background: var(--color-primary-bg);
  color: var(--color-primary);
  border-radius: 8rpx;
  font-size: 24rpx;
}

.script-content {
  background: #FAFAFA;
  border-radius: 12rpx;
  padding: 28rpx;
  line-height: 1.8;
}

.script-text {
  font-size: 28rpx;
  color: var(--color-text-primary);
  white-space: pre-wrap;
  word-break: break-all;
}

/* 话术亮点 */
.script-highlights {
  margin-top: 28rpx;
  padding-top: 24rpx;
  border-top: 1rpx solid var(--color-border);
}

.highlights-title {
  font-size: 26rpx;
  font-weight: 600;
  color: var(--color-text-primary);
  margin-bottom: 16rpx;
}

.highlight-item {
  display: flex;
  gap: 12rpx;
  font-size: 24rpx;
  color: var(--color-text-secondary);
  line-height: 1.8;
}

.highlight-dot {
  color: var(--color-primary-light);
  flex-shrink: 0;
}

/* 操作按钮 */
.action-buttons {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
  margin-top: 32rpx;
}

.action-buttons .btn-outline {
  background: var(--color-white);
}

/* 使用提示 */
.tips-card {
  background: #F0F9FF;
  margin-top: 24rpx;
}

.tips-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #0369A1;
  margin-bottom: 16rpx;
}

.tips-item {
  font-size: 26rpx;
  color: #0C4A6E;
  line-height: 2;
}
